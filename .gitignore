# Dependencies
node_modules/

# TDD harness transient artifacts
# Playwright output (evidence is copied into docs/tdd-evidence/ by safe-pr; raw output stays local)
test-results/
playwright-report/
# ...but the collected, committed evidence under docs/tdd-evidence/ must NEVER be ignored,
# otherwise the screenshots/recordings safe-pr embeds would 404. Re-include that subtree.
!docs/tdd-evidence/**

# safe-pr generated PR bodies
PR_BODY.md
PR_BODY.generated.md

# safe-cleanup recovery log (local record of deleted branch SHAs)
.tdd-branch-cleanup.log
